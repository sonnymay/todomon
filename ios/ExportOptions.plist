<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  App Store export options for `xcodebuild -exportArchive`.
  Replace __APPLE_TEAM_ID__ with your 10-character Apple Developer Team ID
  (Apple Developer → Membership, or Xcode → Settings → Accounts → team).
  Uses automatic signing; if your Xcode is older than 15.3, change the
  `method` value from `app-store-connect` to `app-store`.
-->
<plist version="1.0">
<dict>
  <key>method</key>
  <string>app-store-connect</string>
  <key>destination</key>
  <string>export</string>
  <key>teamID</key>
  <string>__APPLE_TEAM_ID__</string>
  <key>signingStyle</key>
  <string>automatic</string>
  <key>uploadSymbols</key>
  <true/>
  <key>stripSwiftSymbols</key>
  <true/>
</dict>
</plist>
