# Supabase project URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=

# Supabase anon/publishable key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=

# Base URL of the FastAPI backend
VITE_API_BASE_URL=http://localhost:8000

# RevenueCat iOS public SDK key for native StoreKit purchases.
# Required before TestFlight purchase testing.
VITE_REVENUECAT_IOS_API_KEY=

# Build mode. Unset/anything = offline (no login, local-only — good for a standalone
# demo/TestFlight build). Set to 'false' to enable real Supabase auth + server sync
# (requires the Supabase + FastAPI backend deployed and the keys above filled).
VITE_OFFLINE_MODE=
